{
  "name": "workshop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.15.1+sha512.81350b07e53c9538a02f1f2303b4290fa2d7be04e56e2a970c4cc4b417dc761de196edabd49d55c7dc9580db81007c44143e4e3d7e462b3000d23c255122d065",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "packageExtensions": {
      "drizzle-kit": {
        "dependencies": {
          "drizzle-orm": "*"
        }
      }
    }
  },
  "scripts": {
    "dev": "cd packages/gitlab/app && vite",
    "build": "cd packages/gitlab/app && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "cd packages/gitlab/app && vite preview",
    "fetch": "tsx packages/gitlab/fetch-pipelines/fetch-pipelines.ts",
    "fetch:pipelines": "tsx packages/gitlab/fetch-pipelines/fetch-pipelines.ts",
    "fetch:failures": "tsx packages/gitlab/fetch-gitlab-failure/fetch-gitlab-failure.ts",
    "failures:csv": "tsx packages/gitlab/fetch-gitlab-failure/scripts/generate-csvs.ts",
    "transform": "tsx packages/gitlab/transform/src/cli.ts",
    "discover-datasets": "tsx packages/gitlab/app/scripts/discover-datasets.ts",
    "crawl": "tsx packages/resolver-visualizer/crawl.ts",
    "coverage": "tsx packages/coverage-merger/merge-coverage.ts",
    "harvester": "pnpm --parallel --filter './packages/harvester/*' run dev",
    "harvester:doctor": "pnpm --filter @workshop/harvester-backend run doctor",
    "harvester:e2e": "pnpm --filter @workshop/harvester-backend run e2e",
    "transcribe": "pnpm --filter @workshop/transcriber run transcribe",
    "transcriber:setup": "pnpm --filter @workshop/transcriber run setup",
    "transcriber:doctor": "pnpm --filter @workshop/transcriber run doctor",
    "check": "pnpm -r run check"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/node": "^24.6.0",
    "eslint": "^9.36.0",
    "globals": "^16.4.0",
    "ink": "^6.5.1",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0"
  }
}

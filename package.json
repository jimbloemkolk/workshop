{
  "name": "workshop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "cd packages/app && vite",
    "build": "cd packages/app && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "cd packages/app && vite preview",
    "fetch": "tsx packages/fetch-pipelines/fetch-pipelines.ts",
    "fetch:pipelines": "tsx packages/fetch-pipelines/fetch-pipelines.ts",
    "fetch:failures": "tsx packages/fetch-gitlab-failure/fetch-gitlab-failure.ts",
    "failures:csv": "tsx packages/fetch-gitlab-failure/scripts/generate-csvs.ts",
    "transform": "tsx packages/transform/src/cli.ts",
    "discover-datasets": "tsx packages/app/scripts/discover-datasets.ts",
    "check": "pnpm -r run check"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/node": "^24.6.0",
    "eslint": "^9.36.0",
    "globals": "^16.4.0",
    "ink": "^6.5.1",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0"
  }
}

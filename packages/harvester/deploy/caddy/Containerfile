# Caddy for applepie's own ingress: Cloudflare DNS provider (Let's Encrypt DNS-01 for the
# *.staging.applepie.company wildcard — WAN inbound is dropped, so HTTP-01 can't reach us)
# + caddy-l4 (raw TCP forwarding for LiveKit's ICE-TCP media port; core caddy only proxies
# HTTP). Built on the host by caddy.build, not pulled. Unpinned caddy:2 to match the main
# ingress build's convention.
FROM docker.io/library/caddy:2-builder AS build
RUN xcaddy build \
    --with github.com/caddy-dns/cloudflare \
    --with github.com/mholt/caddy-l4

FROM docker.io/library/caddy:2
COPY --from=build /usr/bin/caddy /usr/bin/caddy

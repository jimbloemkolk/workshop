# Harvester (applepie) non-secret environment — read by harvester-app.container via
# EnvironmentFile= straight off the deploy rsync target (/data/apps/...). Everything
# here is safe to commit; the two secrets (LIVEKIT_API_SECRET, HF_TOKEN) are injected
# by the unit's Secret= lines from the tier user's podman secret store instead.

# Session data — must equal the literal Volume container paths in
# harvester-app.container and harvester-egress.container (same-path volume contract).
HARVESTER_DATA_DIR=/srv/harvester/data

# Vault export dir — same absolute path as the host bind mount in
# harvester-app.container, so paths in exported notes are valid on the host too.
HARVESTER_VAULT_DIR=/data/appdata/applepie/harvester/vault

# Join-link base — Jesse's own applepie.company domain, not jimbloemkolk.nl.
HARVESTER_PUBLIC_URL=https://harvester.staging.applepie.company

# Backend -> LiveKit, over the harvester podman network (container-name DNS).
LIVEKIT_URL=ws://harvester-livekit:7880

# What browsers dial for LiveKit signaling (applepie's own caddy vhosts it and proxies
# the websocket upgrade to loopback 17880). Media does NOT ride this URL: browsers dial
# the applepie node's tailnet IP on ICE-TCP 7881 (see harvester-livekit.container).
LIVEKIT_PUBLIC_URL=wss://livekit-harvester.staging.applepie.company

# The API-key NAME (not secret). Must match the key rendered into livekit.yaml.tpl /
# egress.yaml.tpl; the matching secret value is podman secret
# harvester-livekit-api-secret (32+ chars — LiveKit v1.9 refuses shorter).
LIVEKIT_API_KEY=harvester
